@page "/settings"
@using MudBlazor
@using Triply.Core.Interfaces
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ISubscriptionService SubscriptionService

<PageTitle>Settings - Triply</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
    Settings
</MudText>

<MudText Typo="Typo.body1" Class="mb-4 mud-text-secondary">
    Manage your application settings and preferences
</MudText>

<MudGrid>
    <!-- Company Information -->
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="3">
            <MudCardContent>
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Business" 
                            Size="Size.Large" 
                            Color="Color.Primary" />
                    <MudText Typo="Typo.h6" Align="Align.Center">
                        Company Information
                    </MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary">
                        Company details, DOT/MC numbers, address, and invoice settings
                    </MudText>
                </MudStack>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Text" 
                          Color="Color.Primary" 
                          FullWidth="true"
                          EndIcon="@Icons.Material.Filled.ChevronRight"
                          OnClick="@(() => NavigateTo("/settings/company"))">
                    Configure
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    <!-- Email Setup -->
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="3">
            <MudCardContent>
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Email" 
                            Size="Size.Large" 
                            Color="Color.Info" />
                    <MudText Typo="Typo.h6" Align="Align.Center">
                        Email Setup
                    </MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary">
                        SMTP configuration, email signature, and test connection
                    </MudText>
                </MudStack>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Text" 
                          Color="Color.Info" 
                          FullWidth="true"
                          EndIcon="@Icons.Material.Filled.ChevronRight"
                          OnClick="@(() => NavigateTo("/settings/email"))">
                    Configure
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    <!-- Tax Settings -->
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="3">
            <MudCardContent>
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" 
                            Size="Size.Large" 
                            Color="Color.Warning" />
                    <MudText Typo="Typo.h6" Align="Align.Center">
                        Tax Settings
                    </MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary">
                        Filing status, tax rates, fiscal year, and estimated payments
                    </MudText>
                </MudStack>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Text" 
                          Color="Color.Warning" 
                          FullWidth="true"
                          EndIcon="@Icons.Material.Filled.ChevronRight"
                          OnClick="@(() => NavigateTo("/settings/tax"))">
                    Configure
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    <!-- Data Management -->
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="3">
            <MudCardContent>
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Storage" 
                            Size="Size.Large" 
                            Color="Color.Secondary" />
                    <MudText Typo="Typo.h6" Align="Align.Center">
                        Data Management
                    </MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary">
                        Export, import, and manage your application data
                    </MudText>
                </MudStack>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Text" 
                          Color="Color.Secondary" 
                          FullWidth="true"
                          EndIcon="@Icons.Material.Filled.ChevronRight"
                          OnClick="@(() => NavigateTo("/settings/data"))">
                    Manage
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    <!-- Notifications -->
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="3">
            <MudCardContent>
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Notifications" 
                            Size="Size.Large" 
                            Color="Color.Warning" />
                    <MudText Typo="Typo.h6" Align="Align.Center">
                        Notifications
                    </MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary">
                        Configure alerts and notification preferences
                    </MudText>
                </MudStack>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Text" 
                          Color="Color.Warning" 
                          FullWidth="true"
                          EndIcon="@Icons.Material.Filled.ChevronRight"
                          OnClick="@(() => NavigateTo("/settings/notifications"))">
                    Configure
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
            
    
    <!-- About -->
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="3">
            <MudCardContent>
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Info" 
                            Size="Size.Large" 
                            Color="Color.Default" />
                    <MudText Typo="Typo.h6" Align="Align.Center">
                        About Triply
                    </MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary">
                        Version information, licenses, and support
                    </MudText>
                </MudStack>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Text" 
                          Color="Color.Default" 
                          FullWidth="true"
                          EndIcon="@Icons.Material.Filled.ChevronRight"
                          OnClick="ShowAboutDialog">
                    View
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    <!-- Preferences -->
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="3">
            <MudCardContent>
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Tune" 
                            Size="Size.Large" 
                            Color="Color.Success" />
                    <MudText Typo="Typo.h6" Align="Align.Center">
                        Quick Preferences
                    </MudText>
                </MudStack>
                
                <MudStack Spacing="2" Class="mt-4">
                    <MudSwitch @bind-Value="_darkMode" 
                              Label="Dark Mode" 
                              Color="Color.Primary" 
                              T="bool" />
                    
                    <MudSwitch @bind-Value="_notifications" 
                              Label="Notifications" 
                              Color="Color.Primary" 
                              T="bool" />
                    
                    <MudSwitch @bind-Value="_autoSave" 
                              Label="Auto-Save" 
                              Color="Color.Primary" 
                              T="bool" />
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Admin Setup (Developer/Owner Only) -->
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="3" Style="@(_isAdmin ? "border: 3px solid var(--mud-palette-success);" : "border: 2px solid var(--mud-palette-warning);")">
            <MudCardContent>
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" 
                            Size="Size.Large" 
                            Color="@(_isAdmin ? Color.Success : Color.Warning)" />
                    <MudText Typo="Typo.h6" Align="Align.Center">
                        Admin Access
                    </MudText>

                    @if (_isAdmin)
                    {
                        <MudAlert Severity="Severity.Success" Dense="true">
                            <strong>✅ Admin Enabled</strong><br/>
                            You have unlimited access!
                        </MudAlert>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary">
                            Owner/Developer: Enable unlimited access
                        </MudText>
                    }

                    @if (!string.IsNullOrEmpty(_currentUserId))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            User ID: @_currentUserId.Substring(0, Math.Min(20, _currentUserId.Length))...
                        </MudText>
                    }
                </MudStack>
            </MudCardContent>
            <MudCardActions>
                @if (!_isAdmin)
                {
                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Warning" 
                              FullWidth="true"
                              StartIcon="@Icons.Material.Filled.VpnKey"
                              OnClick="SetupAdminAccessAsync">
                        Setup Admin Access
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Outlined" 
                              Color="Color.Default" 
                              FullWidth="true"
                              StartIcon="@Icons.Material.Filled.Refresh"
                              OnClick="CheckAdminStatusAsync">
                        Refresh Status
                    </MudButton>
                }
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private bool _darkMode = false;
    private bool _notifications = true;
    private bool _autoSave = true;
    private bool _isAdmin = false;
    private string _currentUserId = "";

    protected override async Task OnInitializedAsync()
    {
        await CheckAdminStatusAsync();
    }

    private async Task CheckAdminStatusAsync()
    {
        _isAdmin = await SubscriptionService.IsAdminAsync();
        _currentUserId = Preferences.Get("DeviceUserId", "Not Set");
        StateHasChanged();
    }

    private void NavigateTo(string url)
    {
        NavigationManager.NavigateTo(url);
    }

    private void ShowAboutDialog()
    {
        NavigationManager.NavigateTo("/about");
    }

    private async Task SetupAdminAccessAsync()
    {
        var parameters = new DialogParameters
        {
            { "ContentText", "This will give you unlimited access to all features without any subscription. Only enable this if you are the app owner/developer.\n\nContinue?" },
            { "ButtonText", "Yes, Enable Admin" },
            { "Color", Color.Warning }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Enable Admin Access", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            // Set admin user ID
            Preferences.Set("DeviceUserId", "admin@triply.app");

            // Immediately check status
            await CheckAdminStatusAsync();

            if (_isAdmin)
            {
                Snackbar.Add("✅ Admin access enabled! You now have unlimited access!", Severity.Success, config =>
                {
                    config.VisibleStateDuration = 5000;
                });
            }
            else
            {
                Snackbar.Add("⚠️ Admin setup complete. Please restart the app to apply changes.", Severity.Warning);
            }
        }
    }
}
