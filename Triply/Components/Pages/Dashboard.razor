    private string GetActivityIcon(string type)
    {
        return type switch
        {
            "Expense" => Icons.Material.Filled.Receipt,
            "Invoice" => Icons.Material.Filled.Description,
            "Payment" => Icons.Material.Filled.Payment,
            "Fuel" => Icons.Material.Filled.LocalGasStation,
            _ => Icons.Material.Filled.Circle
        };
    }

    private Color GetActivityColor(string type)
    {
        return type switch
        {
            "Expense" => Color.Error,
            "Invoice" => Color.Success,
            "Payment" => Color.Primary,
            "Fuel" => Color.Warning,
            _ => Color.Default
        };
    }

