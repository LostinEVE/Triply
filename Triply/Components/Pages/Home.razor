@page "/"
@using MudBlazor
@inject NavigationManager NavigationManager

@code {
    protected override void OnInitialized()
    {
        // Redirect to dashboard
        NavigationManager.NavigateTo("/dashboard", replace: true);
    }
}


<MudText Typo="Typo.h4" GutterBottom="true" Class="mb-6">
    <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
    Dashboard
</MudText>

<MudGrid Spacing="3">
    <!-- Quick Stats -->
    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="3">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <div>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Active Loads</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Primary">12</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Large" Color="Color.Primary" />
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="3">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <div>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Unpaid Invoices</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Warning">$45,250</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Large" Color="Color.Warning" />
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="3">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <div>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Monthly Revenue</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Success">$128,400</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Large" Color="Color.Success" />
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="3">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <div>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Profit Margin</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Info">18.5%</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.ShowChart" Size="Size.Large" Color="Color.Info" />
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Quick Actions -->
    <MudItem xs="12">
        <MudCard Elevation="3">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.FlashOn" Class="mr-2" />
                        Quick Actions
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudStack Row="true" Spacing="3" Wrap="Wrap.Wrap">
                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Primary" 
                              StartIcon="@Icons.Material.Filled.Add"
                              OnClick="@(() => NavigationManager.NavigateTo("/loads/add"))">
                        New Load
                    </MudButton>
                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Success" 
                              StartIcon="@Icons.Material.Filled.Description"
                              OnClick="@(() => NavigationManager.NavigateTo("/invoices/create"))">
                        Create Invoice
                    </MudButton>
                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Warning" 
                              StartIcon="@Icons.Material.Filled.LocalGasStation"
                              OnClick="@(() => NavigationManager.NavigateTo("/fuel/add"))">
                        Log Fuel
                    </MudButton>
                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Error" 
                              StartIcon="@Icons.Material.Filled.Receipt"
                              OnClick="@(() => NavigationManager.NavigateTo("/expenses/add"))">
                        Add Expense
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" 
                              Color="Color.Info" 
                              StartIcon="@Icons.Material.Filled.Assessment"
                              OnClick="@(() => NavigationManager.NavigateTo("/reports"))">
                        View Reports
                    </MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Recent Activity -->
    <MudItem xs="12" md="6">
        <MudCard Elevation="3" Style="height: 400px;">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.History" Class="mr-2" />
                        Recent Loads
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Color="Color.Default" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent Class="pa-0">
                <MudList T="string" Clickable="true" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.LocalShipping" IconColor="Color.Primary">
                        <MudText Typo="Typo.body2">
                            <strong>L-2024-0045</strong> - Dallas, TX → Atlanta, GA
                        </MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            In Transit • $2,400
                        </MudText>
                    </MudListItem>
                    <MudDivider />
                    <MudListItem T="string" Icon="@Icons.Material.Filled.LocalShipping" IconColor="Color.Success">
                        <MudText Typo="Typo.body2">
                            <strong>L-2024-0044</strong> - Chicago, IL → Houston, TX
                        </MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            Delivered • $2,850
                        </MudText>
                    </MudListItem>
                    <MudDivider />
                    <MudListItem T="string" Icon="@Icons.Material.Filled.LocalShipping" IconColor="Color.Info">
                        <MudText Typo="Typo.body2">
                            <strong>L-2024-0043</strong> - Los Angeles, CA → Phoenix, AZ
                        </MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            Scheduled • $1,800
                        </MudText>
                    </MudListItem>
                </MudList>
            </MudCardContent>
            <MudCardActions>
                <MudButton Color="Color.Primary" Variant="Variant.Text" OnClick="@(() => NavigationManager.NavigateTo("/loads"))">
                    View All Loads
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    <!-- Outstanding Invoices -->
    <MudItem xs="12" md="6">
        <MudCard Elevation="3" Style="height: 400px;">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Class="mr-2" />
                        Outstanding Invoices
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Color="Color.Default" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent Class="pa-0">
                <MudList T="string" Clickable="true" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Warning" IconColor="Color.Error">
                        <MudText Typo="Typo.body2">
                            <strong>INV-2024-0156</strong> - XYZ Logistics
                        </MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            15 days overdue • $8,500
                        </MudText>
                    </MudListItem>
                    <MudDivider />
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Schedule" IconColor="Color.Warning">
                        <MudText Typo="Typo.body2">
                            <strong>INV-2024-0158</strong> - ABC Freight
                        </MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            Due in 5 days • $12,300
                        </MudText>
                    </MudListItem>
                    <MudDivider />
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        <MudText Typo="Typo.body2">
                            <strong>INV-2024-0159</strong> - Global Transport
                        </MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            Due in 28 days • $6,250
                        </MudText>
                    </MudListItem>
                </MudList>
            </MudCardContent>
            <MudCardActions>
                <MudButton Color="Color.Primary" Variant="Variant.Text" OnClick="@(() => NavigationManager.NavigateTo("/invoices"))">
                    View All Invoices
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    <!-- Alerts & Notifications -->
    <MudItem xs="12">
        <MudCard Elevation="3">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Notifications" Class="mr-2" />
                        Alerts & Reminders
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="2">
                    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true">
                        <MudText Typo="Typo.body2">
                            <strong>Truck #T-001</strong> - Preventive maintenance due in 250 miles
                        </MudText>
                    </MudAlert>
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true">
                        <MudText Typo="Typo.body2">
                            <strong>Q1 2024 IFTA Report</strong> - Due April 30, 2024 (15 days remaining)
                        </MudText>
                    </MudAlert>
                    <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Dense="true">
                        <MudText Typo="Typo.body2">
                            <strong>Quarterly Tax Payment</strong> - Estimated $8,450 due by January 15
                        </MudText>
                    </MudAlert>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    protected override async Task OnInitializedAsync()
    {
        // TODO: Load real dashboard data
        await Task.CompletedTask;
    }
}
