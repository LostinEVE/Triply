@page "/settings/notifications"
@using MudBlazor
@using Triply.Core.Interfaces
@using CoreNotificationSettings = Triply.Core.Models.NotificationSettings
@inject INotificationService NotificationService
@inject ISnackbar Snackbar

<PageTitle>Notification Settings - Triply</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Notifications" Class="mr-2" />
    Notification Settings
</MudText>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_settings != null)
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">General Settings</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudStack Spacing="3">
                        <MudSwitch @bind-Value="_settings.EnableNotifications" 
                                  Label="Enable Notifications" 
                                  Color="Color.Primary" />
                        
                        <MudNumericField @bind-Value="_settings.CheckIntervalMinutes" 
                                        Label="Check Interval (minutes)"
                                        Min="5" 
                                        Max="1440"
                                        Disabled="@(!_settings.EnableNotifications)" />
                        
                        <MudDivider />
                        
                        <MudText Typo="Typo.subtitle1">Alert Categories</MudText>
                        
                        <MudSwitch @bind-Value="_settings.EnableInvoiceAlerts" 
                                  Label="Invoice Alerts"
                                  Disabled="@(!_settings.EnableNotifications)" 
                                  Color="Color.Primary" />
                        
                        @if (_settings.EnableInvoiceAlerts)
                        {
                            <MudNumericField @bind-Value="_settings.InvoiceDueWarningDays" 
                                            Label="Invoice Due Warning (days)"
                                            Min="1" 
                                            Max="30"
                                            Class="ml-8" />
                        }
                        
                        <MudSwitch @bind-Value="_settings.EnableMaintenanceAlerts" 
                                  Label="Maintenance Alerts"
                                  Disabled="@(!_settings.EnableNotifications)" 
                                  Color="Color.Primary" />
                        
                        @if (_settings.EnableMaintenanceAlerts)
                        {
                            <MudNumericField @bind-Value="_settings.MaintenanceDueWarningDays" 
                                            Label="Maintenance Due Warning (days)"
                                            Min="1" 
                                            Max="30"
                                            Class="ml-8" />
                        }
                        
                        <MudSwitch @bind-Value="_settings.EnableDocumentAlerts" 
                                  Label="Document Expiry Alerts"
                                  Disabled="@(!_settings.EnableNotifications)" 
                                  Color="Color.Primary" />
                        
                        @if (_settings.EnableDocumentAlerts)
                        {
                            <MudNumericField @bind-Value="_settings.DocumentExpiryWarningDays" 
                                            Label="Document Expiry Warning (days)"
                                            Min="1" 
                                            Max="90"
                                            Class="ml-8" />
                        }
                        
                        <MudSwitch @bind-Value="_settings.EnableTaxAlerts" 
                                  Label="Tax Payment Alerts"
                                  Disabled="@(!_settings.EnableNotifications)" 
                                  Color="Color.Primary" />
                        
                        <MudSwitch @bind-Value="_settings.EnableIFTAAlerts" 
                                  Label="IFTA Filing Alerts"
                                  Disabled="@(!_settings.EnableNotifications)" 
                                  Color="Color.Primary" />
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
        
        <MudItem xs="12" md="4">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Quick Actions</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudStack Spacing="2">
                        <MudButton Variant="Variant.Filled" 
                                  Color="Color.Primary" 
                                  StartIcon="@Icons.Material.Filled.Save"
                                  OnClick="SaveSettingsAsync"
                                  FullWidth="true">
                            Save Settings
                        </MudButton>
                        
                        <MudButton Variant="Variant.Outlined" 
                                  Color="Color.Default" 
                                  StartIcon="@Icons.Material.Filled.Refresh"
                                  OnClick="CheckNowAsync"
                                  FullWidth="true"
                                  Disabled="@(!_settings.EnableNotifications)">
                            Check Now
                        </MudButton>
                        
                        <MudButton Variant="Variant.Outlined" 
                                  Color="Color.Secondary" 
                                  StartIcon="@Icons.Material.Filled.Notifications"
                                  OnClick="@(() => NavigationManager.NavigateTo("/notifications"))"
                                  FullWidth="true">
                            View Notifications
                        </MudButton>
                    </MudStack>
                </MudCardContent>
            </MudCard>
            
            <MudCard Elevation="3" Class="mt-3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                            About Notifications
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudList Dense="true" T="string">
                        <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success" T="string">
                            Notifications run in the background
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success" T="string">
                            Check interval determines how often alerts are updated
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success" T="string">
                            Warning days control when you're alerted before due dates
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success" T="string">
                            All data stays local on your device
                        </MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    private bool _loading = true;
    private CoreNotificationSettings? _settings;

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAsync();
    }

    private async Task LoadSettingsAsync()
    {
        _loading = true;
        try
        {
            _settings = await NotificationService.GetSettingsAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveSettingsAsync()
    {
        if (_settings == null) return;
        
        try
        {
            await NotificationService.SaveSettingsAsync(_settings);
            Snackbar.Add("Settings saved successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving settings: {ex.Message}", Severity.Error);
        }
    }

    private async Task CheckNowAsync()
    {
        try
        {
            await NotificationService.CheckAndNotifyAsync();
            Snackbar.Add("Notifications checked successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error checking notifications: {ex.Message}", Severity.Error);
        }
    }
}
