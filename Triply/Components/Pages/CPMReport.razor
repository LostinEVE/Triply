    private async Task ExportToPDFAsync()
    {
        try
        {
            if (_report == null) return;
            
            var pdfBytes = await PdfService.GenerateCPMReportAsync(_report, _companySettings);
            
            var fileName = $"CPM_{_report.StartDate:yyyyMMdd}_{_report.EndDate:yyyyMMdd}.pdf";
            Snackbar.Add("PDF generated successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating PDF: {ex.Message}", Severity.Error);
        }
    }

