@page "/loads"
@using MudBlazor
@using Microsoft.EntityFrameworkCore
@using Triply.Core.Models
@using Triply.Core.Enums
@using Triply.Core.Interfaces
@using Triply.Components.Shared
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IUnitOfWork UnitOfWork
@inject IDialogService DialogService

<PageTitle>Loads - Triply</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">
        <MudIcon Icon="@Icons.Material.Filled.Inventory" Class="mr-2" />
        Loads
        @if (_loads != null)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ml-2">@_loads.Count total</MudChip>
        }
    </MudText>
    
    <MudButton Variant="Variant.Filled" 
              Color="Color.Primary" 
              StartIcon="@Icons.Material.Filled.Add"
              OnClick="OpenQuickAddLoadAsync">
        Add Load
    </MudButton>
</MudStack>

<MudCard Elevation="3" Class="mb-3">
    <MudCardContent>
        <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudTextField @bind-Value="_searchString"
                         Placeholder="Search loads..."
                         Adornment="Adornment.Start"
                         AdornmentIcon="@Icons.Material.Filled.Search"
                         Immediate="true"
                         DebounceInterval="300"
                         OnDebounceIntervalElapsed="SearchLoads"
                         Class="flex-grow-1" />

            <MudSelect @bind-Value="_selectedStatus"
                      Label="Status"
                      T="LoadStatus?"
                      Clearable="true"
                      Variant="Variant.Outlined"
                      Style="min-width: 150px;">
                <MudSelectItem T="LoadStatus?" Value="@((LoadStatus?)null)">All Statuses</MudSelectItem>
                @foreach (LoadStatus status in Enum.GetValues(typeof(LoadStatus)))
                {
                    <MudSelectItem T="LoadStatus?" Value="@status">@status</MudSelectItem>
                }
            </MudSelect>

            <MudSelect @bind-Value="_selectedCustomerId"
                      Label="Customer"
                      T="Guid?"
                      Clearable="true"
                      Variant="Variant.Outlined"
                      Style="min-width: 200px;">
                <MudSelectItem T="Guid?" Value="@((Guid?)null)">All Customers</MudSelectItem>
                @foreach (var customer in _customers)
                {
                    <MudSelectItem T="Guid?" Value="@customer.CustomerId">@customer.CompanyName</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </MudCardContent>
</MudCard>

<MudCard Elevation="3">
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true">
        <MudTabPanel Text="All" Icon="@Icons.Material.Filled.List">
            <LoadsDataGrid Loads="@_filteredLoads" OnRefresh="@LoadLoadsAsync" />
        </MudTabPanel>
        
        <MudTabPanel Text="Booked" Icon="@Icons.Material.Filled.BookmarkAdded" BadgeData="@(_bookedCount > 0 ? _bookedCount : null)" BadgeColor="Color.Info">
            <LoadsDataGrid Loads="@_filteredLoads.Where(l => l.Status == LoadStatus.Booked).ToList()" OnRefresh="@LoadLoadsAsync" />
        </MudTabPanel>

        <MudTabPanel Text="In Transit" Icon="@Icons.Material.Filled.LocalShipping" BadgeData="@(_inTransitCount > 0 ? _inTransitCount : null)" BadgeColor="Color.Primary">
            <LoadsDataGrid Loads="@_filteredLoads.Where(l => l.Status == LoadStatus.InTransit).ToList()" OnRefresh="@LoadLoadsAsync" />
        </MudTabPanel>

        <MudTabPanel Text="Delivered" Icon="@Icons.Material.Filled.CheckCircle" BadgeData="@(_deliveredCount > 0 ? _deliveredCount : null)" BadgeColor="Color.Success">
            <LoadsDataGrid Loads="@_filteredLoads.Where(l => l.Status == LoadStatus.Delivered).ToList()" OnRefresh="@LoadLoadsAsync" />
        </MudTabPanel>
    </MudTabs>
</MudCard>

@code {
    private List<Load> _loads = new();
    private List<Load> _filteredLoads = new();
    private List<Customer> _customers = new();
    private string _searchString = "";
    private LoadStatus? _selectedStatus;
    private Guid? _selectedCustomerId;
    
    private int _bookedCount = 0;
    private int _inTransitCount = 0;
    private int _deliveredCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomersAsync();
        await LoadLoadsAsync();
    }

    private async Task LoadCustomersAsync()
    {
        try
        {
            _customers = await UnitOfWork.Customers.GetQueryable()
                .Where(c => c.IsActive)
                .OrderBy(c => c.CompanyName)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading customers: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadLoadsAsync()
    {
        try
        {
            var query = UnitOfWork.Loads.GetQueryable()
                .Include(l => l.Customer)
                .Include(l => l.Truck);

            _loads = await query
                .OrderByDescending(l => l.PickupDate)
                .ToListAsync();

            FilterLoads();
            UpdateCounts();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading loads: {ex.Message}", Severity.Error);
        }
    }

    private void SearchLoads(string searchText)
    {
        FilterLoads();
    }

    private void FilterLoads()
    {
        _filteredLoads = _loads;

        // Apply search filter
        if (!string.IsNullOrWhiteSpace(_searchString))
        {
            _filteredLoads = _filteredLoads.Where(l =>
                l.LoadNumber.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                (l.PickupCity?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (l.DeliveryCity?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (l.Customer?.CompanyName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false)
            ).ToList();
        }

        // Apply status filter
        if (_selectedStatus.HasValue)
        {
            _filteredLoads = _filteredLoads.Where(l => l.Status == _selectedStatus.Value).ToList();
        }

        // Apply customer filter
        if (_selectedCustomerId.HasValue)
        {
            _filteredLoads = _filteredLoads.Where(l => l.CustomerId == _selectedCustomerId.Value).ToList();
        }

        UpdateCounts();
    }

    private void UpdateCounts()
    {
        _bookedCount = _filteredLoads.Count(l => l.Status == LoadStatus.Booked);
        _inTransitCount = _filteredLoads.Count(l => l.Status == LoadStatus.InTransit);
        _deliveredCount = _filteredLoads.Count(l => l.Status == LoadStatus.Delivered);
    }

    private async Task OpenQuickAddLoadAsync()
    {
        var parameters = new DialogParameters
        {
            { "OnLoadCreated", EventCallback.Factory.Create<Guid>(this, async (loadId) =>
                {
                    await LoadLoadsAsync();
                    Snackbar.Add("Load created successfully", Severity.Success);
                })
            }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseButton = true
        };

        await DialogService.ShowAsync<QuickAddLoad>("Add New Load", parameters, options);
    }
}
