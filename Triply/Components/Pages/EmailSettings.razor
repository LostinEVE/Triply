@page "/settings/email"
@using MudBlazor
@using Microsoft.EntityFrameworkCore
@using CoreCompanySettings = Triply.Core.Models.CompanySettings
@using Triply.Core.Interfaces
@inject IUnitOfWork UnitOfWork
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>Email Settings - Triply</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4"></MudBreadcrumbs>

<MudText Typo="Typo.h4" GutterBottom="true" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Email" Class="mr-2" />
    Email Settings
</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudCard Elevation="3">
        <MudCardContent>
            <MudGrid>
                <!-- SMTP Server Configuration -->
                <MudItem xs="12">
                    <MudText Typo="Typo.h6" Class="mb-3">SMTP Server Configuration</MudText>
                    <MudDivider Class="mb-4" />
                </MudItem>
                
                <MudItem xs="12" md="8">
                    <MudTextField @bind-Value="_settings.SMTPServer" 
                                 Label="SMTP Server" 
                                 Variant="Variant.Outlined"
                                 HelperText="e.g., smtp.gmail.com" />
                </MudItem>
                
                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="_settings.SMTPPort" 
                                    Label="Port" 
                                    Variant="Variant.Outlined"
                                    HelperText="Usually 587 or 465"
                                    Min="1"
                                    Max="65535"
                                    T="int" />
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_settings.SMTPUsername" 
                                 Label="Username / Email" 
                                 Variant="Variant.Outlined"
                                 InputType="InputType.Email" />
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_settings.SMTPPassword" 
                                 Label="Password" 
                                 Variant="Variant.Outlined"
                                 InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                 Adornment="Adornment.End"
                                 AdornmentIcon="@(_showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                 OnAdornmentClick="TogglePasswordVisibility" />
                </MudItem>
                
                <MudItem xs="12">
                    <MudSwitch @bind-Value="_settings.UseSSL" 
                              Label="Use SSL/TLS" 
                              Color="Color.Primary"
                              T="bool" />
                    <MudText Typo="Typo.caption" Class="ml-12 mud-text-secondary">
                        Recommended for secure email transmission
                    </MudText>
                </MudItem>
                
                <!-- Sender Information -->
                <MudItem xs="12">
                    <MudText Typo="Typo.h6" Class="mb-3 mt-4">Sender Information</MudText>
                    <MudDivider Class="mb-4" />
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_settings.FromEmail" 
                                 Label="From Email" 
                                 Variant="Variant.Outlined"
                                 InputType="InputType.Email"
                                 HelperText="Email address that appears in 'From' field" />
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_settings.FromName" 
                                 Label="From Name" 
                                 Variant="Variant.Outlined"
                                 HelperText="Name that appears in 'From' field" />
                </MudItem>
                
                <!-- Email Signature -->
                <MudItem xs="12">
                    <MudText Typo="Typo.h6" Class="mb-3 mt-4">Email Signature</MudText>
                    <MudDivider Class="mb-4" />
                </MudItem>
                
                <MudItem xs="12">
                    <MudTextField @bind-Value="_settings.EmailSignature" 
                                 Label="Email Signature" 
                                 Variant="Variant.Outlined"
                                 Lines="6"
                                 HelperText="This signature will be appended to all outgoing emails" />
                    
                    @if (!string.IsNullOrEmpty(_settings.EmailSignature))
                    {
                        <MudPaper Class="pa-3 mt-3" Elevation="0" Style="background-color: #f5f5f5;">
                            <MudText Typo="Typo.caption" Class="mb-2"><strong>Preview:</strong></MudText>
                            <MudText Typo="Typo.body2" Style="white-space: pre-line;">@_settings.EmailSignature</MudText>
                        </MudPaper>
                    }
                </MudItem>
                
                <!-- Test Connection -->
                <MudItem xs="12">
                    <MudText Typo="Typo.h6" Class="mb-3 mt-4">Test Configuration</MudText>
                    <MudDivider Class="mb-4" />
                </MudItem>
                
                <MudItem xs="12" md="8">
                    <MudTextField @bind-Value="_testEmail" 
                                 Label="Test Email Address" 
                                 Variant="Variant.Outlined"
                                 InputType="InputType.Email"
                                 HelperText="Enter an email address to receive a test message" />
                </MudItem>
                
                <MudItem xs="12" md="4">
                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Info" 
                              FullWidth="true"
                              OnClick="SendTestEmailAsync"
                              Disabled="@_sendingTest">
                        @if (_sendingTest)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                            <span class="ml-2">Sending...</span>
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Send" Class="mr-2" />
                            <span>Send Test Email</span>
                        }
                    </MudButton>
                </MudItem>
                
                @if (_testResult != null)
                {
                    <MudItem xs="12">
                        <MudAlert Severity="@(_testSuccess ? Severity.Success : Severity.Error)" 
                                 Dense="true"
                                 Class="mt-2">
                            @_testResult
                        </MudAlert>
                    </MudItem>
                }
            </MudGrid>
        </MudCardContent>
        
        <MudCardActions>
            <MudButton Variant="Variant.Text" 
                      Color="Color.Default" 
                      OnClick="Cancel">
                Cancel
            </MudButton>
            <MudSpacer />
            <MudButton Variant="Variant.Filled" 
                      Color="Color.Primary" 
                      OnClick="SaveAsync"
                      Disabled="@_saving">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    <span class="ml-2">Saving...</span>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Save" Class="mr-2" />
                    <span>Save Changes</span>
                }
            </MudButton>
        </MudCardActions>
    </MudCard>
}

@code {
    private CoreCompanySettings _settings = new();
    private bool _loading = true;
    private bool _saving = false;
    private bool _sendingTest = false;
    private bool _showPassword = false;
    private string _testEmail = "";
    private string? _testResult;
    private bool _testSuccess;

    private List<BreadcrumbItem> _breadcrumbs = new()
    {
        new BreadcrumbItem("Settings", href: "/settings", icon: Icons.Material.Filled.Settings),
        new BreadcrumbItem("Email", href: null, disabled: true)
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAsync();
    }

    private async Task LoadSettingsAsync()
    {
        try
        {
            _loading = true;

            var settings = await UnitOfWork.CompanySettings.GetQueryable().FirstOrDefaultAsync();

            if (settings != null)
            {
                _settings = settings;
            }
            else
            {
                // Create default settings
                _settings = new CoreCompanySettings
                {
                    SMTPPort = 587,
                    UseSSL = true
                };
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading settings: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private async Task SendTestEmailAsync()
    {
        try
        {
            _sendingTest = true;
            _testResult = null;
            
            if (string.IsNullOrWhiteSpace(_testEmail))
            {
                _testResult = "Please enter a test email address";
                _testSuccess = false;
                return;
            }
            
            if (string.IsNullOrWhiteSpace(_settings.SMTPServer) || 
                string.IsNullOrWhiteSpace(_settings.SMTPUsername) ||
                string.IsNullOrWhiteSpace(_settings.SMTPPassword))
            {
                _testResult = "Please configure all SMTP settings before testing";
                _testSuccess = false;
                return;
            }
            
            // TODO: Implement actual email sending using IEmailService
            // For now, simulate success
            await Task.Delay(2000);
            
            _testResult = $"Test email sent successfully to {_testEmail}! Check your inbox.";
            _testSuccess = true;
            Snackbar.Add("Test email sent!", Severity.Success);
        }
        catch (Exception ex)
        {
            _testResult = $"Failed to send test email: {ex.Message}";
            _testSuccess = false;
            Snackbar.Add("Test email failed", Severity.Error);
        }
        finally
        {
            _sendingTest = false;
        }
    }

    private async Task SaveAsync()
    {
        try
        {
            _saving = true;
            
            if (string.IsNullOrWhiteSpace(_settings.SMTPServer))
            {
                Snackbar.Add("SMTP Server is required", Severity.Warning);
                return;
            }
            
            if (_settings.Id == 0)
            {
                await UnitOfWork.CompanySettings.AddAsync(_settings);
            }
            else
            {
                await UnitOfWork.CompanySettings.UpdateAsync(_settings);
            }
            
            await UnitOfWork.SaveChangesAsync();
            
            Snackbar.Add("Email settings saved successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving settings: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/settings");
    }
}
