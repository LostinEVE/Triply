@using MudBlazor
@using Triply.Core.Models
@using Triply.Core.Enums

<MudCard Elevation="3" Class="mb-4">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Schedule" Class="mr-2" />
                Maintenance Schedule
            </MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @if (!_scheduleItems.Any())
        {
            <MudAlert Severity="Severity.Success">
                No upcoming maintenance scheduled!
            </MudAlert>
        }
        else
        {
            @foreach (var truck in Trucks.Where(t => _scheduleItems.Any(s => s.TruckId == t.TruckId)))
            {
                <MudPaper Elevation="2" Class="pa-3 mb-3">
                    <MudText Typo="Typo.h6" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" Class="mr-1" />
                        @truck.TruckId
                    </MudText>
                    <MudText Typo="Typo.caption" Class="mb-3">
                        Current Odometer: @truck.CurrentOdometer.ToString("N0") miles
                    </MudText>
                    
                    @foreach (var item in _scheduleItems.Where(s => s.TruckId == truck.TruckId))
                    {
                        <MudCard Outlined="true" Class="mb-2" Style="@GetScheduleItemStyle(item, truck)">
                            <MudCardContent>
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@GetMaintenanceIcon(item.Type)" 
                                                    Size="Size.Small" 
                                                    Color="@GetScheduleColor(item, truck)" />
                                            <MudText Typo="Typo.body1">
                                                <strong>@item.Type.ToString()</strong>
                                            </MudText>
                                            <MudChip T="string" 
                                                    Size="Size.Small" 
                                                    Color="@GetScheduleColor(item, truck)">
                                                @GetScheduleStatus(item, truck)
                                            </MudChip>
                                        </MudStack>
                                        
                                        @if (!string.IsNullOrEmpty(item.Description))
                                        {
                                            <MudText Typo="Typo.body2">@item.Description</MudText>
                                        }
                                        
                                        <MudStack Row="true" Spacing="3">
                                            @if (item.NextDueDate.HasValue)
                                            {
                                                <MudText Typo="Typo.caption">
                                                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" />
                                                    Due: @item.NextDueDate.Value.ToString("MM/dd/yyyy")
                                                    @if (item.NextDueDate.Value < DateTime.Today)
                                                    {
                                                        <span style="color: red;">
                                                            (@GetDaysOverdue(item.NextDueDate.Value) days overdue)
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span>
                                                            (in @GetDaysUntil(item.NextDueDate.Value) days)
                                                        </span>
                                                    }
                                                </MudText>
                                            }
                                            @if (item.NextDueOdometer.HasValue)
                                            {
                                                <MudText Typo="Typo.caption">
                                                    <MudIcon Icon="@Icons.Material.Filled.Speed" Size="Size.Small" />
                                                    Due at: @item.NextDueOdometer.Value.ToString("N0") mi
                                                    @if (truck.CurrentOdometer >= item.NextDueOdometer.Value)
                                                    {
                                                        <span style="color: red;">
                                                            (@((truck.CurrentOdometer - item.NextDueOdometer.Value).ToString("N0")) mi overdue)
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span>
                                                            (in @((item.NextDueOdometer.Value - truck.CurrentOdometer).ToString("N0")) mi)
                                                        </span>
                                                    }
                                                </MudText>
                                            }
                                        </MudStack>
                                        
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                            Last performed: @item.MaintenanceDate.ToString("MM/dd/yyyy") 
                                            at @item.Odometer.ToString("N0") mi
                                        </MudText>
                                    </MudStack>
                                    
                                    <MudButton Variant="Variant.Filled" 
                                              Color="@GetScheduleColor(item, truck)" 
                                              Size="Size.Small"
                                              StartIcon="@Icons.Material.Filled.Add"
                                              OnClick="@(() => OnCreateMaintenance.InvokeAsync(item))">
                                        Create Record
                                    </MudButton>
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    }
                </MudPaper>
            }
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter]
    public List<Truck> Trucks { get; set; } = new();
    
    [Parameter]
    public List<MaintenanceRecord> MaintenanceRecords { get; set; } = new();
    
    [Parameter]
    public EventCallback<MaintenanceRecord> OnCreateMaintenance { get; set; }
    
    private List<MaintenanceRecord> _scheduleItems = new();

    protected override void OnParametersSet()
    {
        CalculateSchedule();
    }

    private void CalculateSchedule()
    {
        var today = DateTime.Now.Date;
        var thirtyDaysOut = today.AddDays(30);
        
        _scheduleItems = MaintenanceRecords
            .Where(m => m.NextDueDate.HasValue || m.NextDueOdometer.HasValue)
            .Where(m => 
            {
                var truck = Trucks.FirstOrDefault(t => t.TruckId == m.TruckId);
                if (truck == null) return false;
                
                // Include if date is due within 30 days or overdue
                if (m.NextDueDate.HasValue && m.NextDueDate.Value <= thirtyDaysOut)
                    return true;
                
                // Include if odometer is within 1000 miles or overdue
                if (m.NextDueOdometer.HasValue && m.NextDueOdometer.Value <= truck.CurrentOdometer + 1000)
                    return true;
                
                return false;
            })
            .OrderBy(m => m.TruckId)
            .ThenBy(m => GetSchedulePriority(m))
            .ToList();
    }

    private int GetSchedulePriority(MaintenanceRecord record)
    {
        var truck = Trucks.FirstOrDefault(t => t.TruckId == record.TruckId);
        if (truck == null) return 999;
        
        var today = DateTime.Now.Date;
        
        // Overdue items first
        if (record.NextDueDate.HasValue && record.NextDueDate.Value < today)
            return 1;
        
        if (record.NextDueOdometer.HasValue && truck.CurrentOdometer >= record.NextDueOdometer.Value)
            return 1;
        
        // Due soon next
        if (record.NextDueDate.HasValue && record.NextDueDate.Value <= today.AddDays(7))
            return 2;
        
        if (record.NextDueOdometer.HasValue && record.NextDueOdometer.Value <= truck.CurrentOdometer + 200)
            return 2;
        
        return 3;
    }

    private Color GetScheduleColor(MaintenanceRecord record, Truck truck)
    {
        var today = DateTime.Now.Date;
        
        // Overdue = Red
        if (record.NextDueDate.HasValue && record.NextDueDate.Value < today)
            return Color.Error;
        
        if (record.NextDueOdometer.HasValue && truck.CurrentOdometer >= record.NextDueOdometer.Value)
            return Color.Error;
        
        // Due within 7 days or 200 miles = Yellow
        if (record.NextDueDate.HasValue && record.NextDueDate.Value <= today.AddDays(7))
            return Color.Warning;
        
        if (record.NextDueOdometer.HasValue && record.NextDueOdometer.Value <= truck.CurrentOdometer + 200)
            return Color.Warning;
        
        // More than 7 days or 200 miles out = Green
        return Color.Success;
    }

    private string GetScheduleStatus(MaintenanceRecord record, Truck truck)
    {
        var today = DateTime.Now.Date;
        
        // Check overdue
        if (record.NextDueDate.HasValue && record.NextDueDate.Value < today)
            return "OVERDUE";
        
        if (record.NextDueOdometer.HasValue && truck.CurrentOdometer >= record.NextDueOdometer.Value)
            return "OVERDUE";
        
        // Check due soon
        if (record.NextDueDate.HasValue && record.NextDueDate.Value <= today.AddDays(7))
            return "DUE SOON";
        
        if (record.NextDueOdometer.HasValue && record.NextDueOdometer.Value <= truck.CurrentOdometer + 200)
            return "DUE SOON";
        
        return "UPCOMING";
    }

    private string GetScheduleItemStyle(MaintenanceRecord record, Truck truck)
    {
        var color = GetScheduleColor(record, truck);
        
        return color switch
        {
            Color.Error => "border-left: 4px solid #f44336;",
            Color.Warning => "border-left: 4px solid #ff9800;",
            Color.Success => "border-left: 4px solid #4caf50;",
            _ => ""
        };
    }

    private int GetDaysUntil(DateTime dueDate)
    {
        return (dueDate - DateTime.Today).Days;
    }

    private int GetDaysOverdue(DateTime dueDate)
    {
        return (DateTime.Today - dueDate).Days;
    }

    private string GetMaintenanceIcon(MaintenanceType type)
    {
        return type switch
        {
            MaintenanceType.OilChange => Icons.Material.Filled.WaterDrop,
            MaintenanceType.Tires => Icons.Material.Filled.Circle,
            MaintenanceType.Brakes => Icons.Material.Filled.StopCircle,
            MaintenanceType.Transmission => Icons.Material.Filled.Settings,
            MaintenanceType.Engine => Icons.Material.Filled.Engineering,
            MaintenanceType.Electrical => Icons.Material.Filled.Bolt,
            MaintenanceType.HVAC => Icons.Material.Filled.Thermostat,
            MaintenanceType.DOTInspection => Icons.Material.Filled.VerifiedUser,
            MaintenanceType.AnnualInspection => Icons.Material.Filled.CheckCircle,
            MaintenanceType.PreventiveMaintenance => Icons.Material.Filled.Schedule,
            MaintenanceType.Repair => Icons.Material.Filled.Build,
            _ => Icons.Material.Filled.Handyman
        };
    }
}
