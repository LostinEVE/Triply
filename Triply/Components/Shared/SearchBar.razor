@using MudBlazor

<MudPaper Elevation="2" Class="pa-3 mb-3">
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        <MudTextField @bind-Value="_searchText"
                     Label="@Label"
                     Placeholder="@Placeholder"
                     Variant="Variant.Outlined"
                     Adornment="Adornment.Start"
                     AdornmentIcon="@Icons.Material.Filled.Search"
                     OnKeyUp="HandleKeyUp"
                     Immediate="true"
                     DebounceInterval="300"
                     FullWidth="true"
                     Class="flex-grow-1" />
        
        @if (!string.IsNullOrEmpty(_searchText))
        {
            <MudIconButton Icon="@Icons.Material.Filled.Clear"
                          OnClick="ClearSearch"
                          Color="Color.Default"
                          Size="Size.Medium" />
        }

        @if (ShowFilters)
        {
            <MudIconButton Icon="@Icons.Material.Filled.FilterList"
                          OnClick="@(() => _showFilters = !_showFilters)"
                          Color="@(_showFilters ? Color.Primary : Color.Default)"
                          Size="Size.Medium" />
        }
    </MudStack>

    @if (_showFilters && FilterContent != null)
    {
        <MudDivider Class="my-3" />
        @FilterContent
    }
</MudPaper>

@code {
    [Parameter]
    public string Label { get; set; } = "Search";

    [Parameter]
    public string Placeholder { get; set; } = "Type to search...";

    [Parameter]
    public EventCallback<string> OnSearch { get; set; }

    [Parameter]
    public bool ShowFilters { get; set; }

    [Parameter]
    public RenderFragment? FilterContent { get; set; }

    private string _searchText = "";
    private bool _showFilters;

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await PerformSearchAsync();
        }
    }

    private async Task PerformSearchAsync()
    {
        if (OnSearch.HasDelegate)
        {
            await OnSearch.InvokeAsync(_searchText);
        }
    }

    private async Task ClearSearch()
    {
        _searchText = "";
        await PerformSearchAsync();
    }

    // Public method to programmatically trigger search
    public async Task SearchAsync(string searchText)
    {
        _searchText = searchText;
        await PerformSearchAsync();
    }
}
