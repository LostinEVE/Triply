@using Triply.Core.Interfaces
@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudText>@Message</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@CancelText</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="Confirm">@ConfirmText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public string Message { get; set; } = "Are you sure you want to continue?";

    [Parameter]
    public string ConfirmText { get; set; } = "Yes";

    [Parameter]
    public string CancelText { get; set; } = "Cancel";

    [Parameter]
    public EventCallback<bool> OnResult { get; set; }

    private async Task Confirm()
    {
        await OnResult.InvokeAsync(true);
    }

    private async Task Cancel()
    {
        await OnResult.InvokeAsync(false);
    }
}
}
